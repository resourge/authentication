{
  "name": "authentication",
  "version": "0.0.0-development",
  "description": "",
  "type": "module",
  "scripts": {
    "postinstall": "patch-package",
    "commit": "git pull && git add . && git-cz",
    "lint": "eslint \"./**/src/**/*.{ts,tsx}\"",
    "lint:prod": "cross-env NODE_ENV=production npm run lint",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "test:watch": "npm run test:watch --workspaces",
    "coverage": "npm run coverage --workspaces",
    "semantic-release:react-authentication": "npm run semantic-release --prefix=./packages/react-authentication",
    "semantic-release": "npm run semantic-release:react-authentication"
  },
  "author": "resourge",
  "license": "MIT",
  "workspaces": [
    "./packages/*"
  ],
  "keywords": [
    "javascript",
    "typescript",
    "authentication",
    "javascript authentication",
    "react authentication",
    "typescript authentication",
    "permissions",
    "javascript permissions",
    "react permissions",
    "typescript permissions"
  ],
  "devDependencies": {
    "@fastify/deepmerge": "^3.2.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/use-sync-external-store": "^1.5.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "app-root-path": "^3.1.0",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint-config-resourge": "^1.8.2",
    "glob": "^13.0.6",
    "jsdom": "^29.1.0",
    "semantic-release": "^25.0.3",
    "semantic-release-monorepo": "^8.0.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/resourge/authentication.git"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@react-native-community/netinfo": "^12.0.1",
    "jwt-decode": "^4.0.0"
  }
}
